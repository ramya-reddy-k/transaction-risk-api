POSTGRES_DB=transactionrisk
POSTGRES_USER=transactionrisk
POSTGRES_PASSWORD=replace-with-a-strong-database-password

JWT_SECRET=replace-with-a-base64-encoded-32-byte-secret
JWT_ISSUER=transaction-risk-api
JWT_TTL=PT1H

DEMO_USERNAME=demo
DEMO_PASSWORD=replace-with-a-strong-demo-password

# Optional Kafka transactional-outbox publisher
KAFKA_ENABLED=false
SPRING_KAFKA_BOOTSTRAP_SERVERS=localhost:9092
KAFKA_TOPIC=transaction-created.v1
KAFKA_PUBLISHER_DELAY_MS=5000
KAFKA_MAXIMUM_ATTEMPTS=5
KAFKA_SEND_TIMEOUT=PT10S
KAFKA_STALE_PROCESSING_TIMEOUT=PT5M
